# Database
DATABASE_URL=postgresql+asyncpg://stonks:stonks_dev@localhost:5432/stonks

# Polygon.io API
POLYGON_API_KEY=your_polygon_api_key_here

# Finnhub API
FINNHUB_API_KEY=your_finnhub_api_key_here

# Backend
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# Signal Defaults
SIGNAL_TARGET_PCT=5.0
SIGNAL_TARGET_DAYS=20
SIGNAL_MAX_DRAWDOWN_PCT=-3.0

# Screener Defaults
SCREENER_MIN_DOLLAR_VOLUME=100000
SCREENER_MIN_PRICE=1.0
